# Connect Gateway configuration
PORT=8787

# Supabase Postgres (Prisma datasource)
# Runtime: Transaction pooler (port 6543, pgbouncer) — use pooler host, not db.xxx.supabase.co
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations: direct connection (port 5432)
# Session pooler (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Upstream Pacto P2P API the gateway proxies to (never exposed to the client SDK)
PACTO_API_URL=
PACTO_API_KEY=

# Secret used to sign session handshakes and webhooks
GATEWAY_SIGNING_SECRET=

# Checkout session TTL in milliseconds (default: 900000 / 15 minutes)
SESSION_TTL_MS=

# Bearer token for /admin/* key management endpoints
GATEWAY_ADMIN_TOKEN=

# Public endpoint rate limiting (per publishable key, in-memory sliding window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Inbound webhook receiver (upstream Pacto -> gateway) signature verification
PACTO_WEBHOOK_SECRET=
# Replay tolerance window for inbound webhook timestamps, in seconds
WEBHOOK_REPLAY_TOLERANCE_SECONDS=300
