generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum KeyMode {
  live
  test
}

enum KeyStatus {
  active
  revoked
}

enum CheckoutMode {
  buy
  sell
}

enum SessionStatus {
  active
  expired
  consumed
  revoked
}

enum WebhookStatus {
  enabled
  disabled
}

enum WebhookDeliveryStatus {
  pending
  succeeded
  failed
  dead
}

enum IdempotencyStatus {
  pending
  completed
}

model ApiKey {
  id             String           @id @default(cuid())
  publishableKey String           @unique
  secretKeyHash  String
  secretLast4    String
  mode           KeyMode          @default(test)
  allowedOrigins String[]
  status         KeyStatus        @default(active)
  label          String?
  quoteSpreadBps Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  checkoutSessions   CheckoutSession[]
  webhookEndpoints   WebhookEndpoint[]
  webhookEvents      WebhookEvent[]

  @@index([publishableKey])
  @@index([status])
}

model CheckoutSession {
  id               String        @id @default(cuid())
  apiKeyId         String
  apiKey           ApiKey        @relation(fields: [apiKeyId], references: [id])
  mode             CheckoutMode
  listingId        String?
  quote            Json?
  clientSecretHash String
  status           SessionStatus @default(active)
  expiresAt        DateTime
  refreshCount     Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([apiKeyId])
  @@index([status])
}

model WebhookEndpoint {
  id            String                @id @default(cuid())
  apiKeyId      String
  apiKey        ApiKey                @relation(fields: [apiKeyId], references: [id])
  url           String
  secret        String
  enabledEvents String[]
  status        WebhookStatus         @default(enabled)
  verified      Boolean               @default(false)
  description   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deliveries    WebhookDelivery[]

  @@index([apiKeyId])
  @@index([status])
}

model WebhookEvent {
  id         String            @id @default(cuid())
  apiKeyId   String
  apiKey     ApiKey            @relation(fields: [apiKeyId], references: [id])
  type       String
  data       Json
  sourceEventId String? @unique
  createdAt  DateTime          @default(now())
  deliveries WebhookDelivery[]

  @@index([apiKeyId])
  @@index([type])
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  endpoint       WebhookEndpoint       @relation(fields: [endpointId], references: [id])
  eventId        String
  event          WebhookEvent          @relation(fields: [eventId], references: [id])
  eventType      String
  status         WebhookDeliveryStatus @default(pending)
  attempts       Int                   @default(0)
  maxAttempts    Int                   @default(5)
  nextAttemptAt  DateTime              @default(now())
  lastError      String?
  lastStatusCode Int?
  deliveredAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status, nextAttemptAt])
  @@index([endpointId])
  @@index([eventId])
}

model IdempotencyRecord {
  id           String            @id @default(cuid())
  apiKeyId     String
  key          String
  requestHash  String
  status       IdempotencyStatus @default(pending)
  statusCode   Int?
  responseBody String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([apiKeyId, key])
  @@index([createdAt])
}

model WebhookNonce {
  id        String   @id @default(cuid())
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
