{
  "name": "pacto-connect",
  "version": "0.0.0",
  "private": true,
  "description": "Embeddable SDK + widget to add Pacto P2P stablecoin buy/sell flows to any site.",
  "packageManager": "npm@11.2.0",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "biome format --write .",
    "check": "biome check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.1",
    "@changesets/cli": "^2.27.9",
    "next": "^14.2.18",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "next": "^14.2.18"
  },
  "engines": {
    "node": ">=20"
  }
}
